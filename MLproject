name: product-review-sentiment-mlops

entry_points:
  main:
    parameters:
      config_path: {type: str, default: "configs/data_config.json"}
    command: >
      python -m ml.data_ingestion.ingest --config {config_path} &&
      python -m ml.validation.validate_data --config {config_path} &&
      python -m ml.eda.analyze --config {config_path} &&
      python -m ml.preprocessing.preprocess --config {config_path} &&
      python -m ml.features.compute_baseline &&
      python -m ml.training.train &&
      python -m ml.evaluation.evaluate &&
      python -m ml.monitoring.drift &&
      python -m ml.monitoring.publish_report

  train:
    command: python -m ml.training.train
